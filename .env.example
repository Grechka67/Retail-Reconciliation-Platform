# ShopOS — local dev environment
# Copy to .env and fill in. NEVER commit .env.

# --- Database -------------------------------------------------------
# Use a strong, unique password. The stack refuses to start with a default/blank one.
POSTGRES_DB=project_ot
POSTGRES_USER=ot_admin
POSTGRES_PASSWORD=

# --- Admin API key (REQUIRED) ---------------------------------------
# Guards every /admin/* and /ingest/admin/* endpoint via the X-API-Key header.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_API_KEY=

# --- Loyverse POS ---------------------------------------------------
# Get a Personal Access Token from https://developer.loyverse.com/
LOYVERSE_API_TOKEN=

# --- KBank SMS bridge (REQUIRED) ------------------------------------
# Shared HMAC secret between the Android SMS-Forwarder app and our /ingest/kbank/sms webhook.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
KBANK_SMS_HMAC_SECRET=

# --- LINE Notify ----------------------------------------------------
# Generate at https://notify-bot.line.me/my/
LINE_NOTIFY_TOKEN=

# --- Metabase -------------------------------------------------------
# Generate a 32+ char key with: python -c "import secrets; print(secrets.token_urlsafe(32))"
METABASE_ENCRYPTION_KEY=

# --- Reconciliation tuning ------------------------------------------
ANOMALY_CASH_THRESHOLD_THB=300
TRANSFER_MATCH_WINDOW_SECONDS=600

# --- Logging --------------------------------------------------------
LOG_LEVEL=INFO
